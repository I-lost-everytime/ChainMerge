{
  "name": "chaincodec-sdk",
  "version": "0.1.2",
  "description": "TypeScript/JavaScript SDK for the ChainCodec multichain transaction decoder API.",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "lint": "echo \"no lint configured\"",
    "prepare": "npm run build"
  },
  "keywords": [
    "blockchain",
    "multichain",
    "sdk",
    "transaction-decoder",
    "chaincodec"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/I-lost-everytime/Chaincodec.git"
  },
  "bugs": {
    "url": "https://github.com/I-lost-everytime/Chaincodec/issues"
  },
  "homepage": "https://github.com/I-lost-everytime/Chaincodec#readme",
  "peerDependencies": {
    "typescript": ">=5.0.0"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "chaincodec-sdk": "^0.1.2"
  }
}
